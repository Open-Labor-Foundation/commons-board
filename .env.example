# commons-board environment — EXAMPLE ONLY. Copy to .env and fill per deployment.
# Never commit real secrets. .env is gitignored.

# ── API server ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# Omit DATABASE_URL to use file-backed persistence (dev only).
DATABASE_URL=postgres://commons:change-me@localhost:5432/commons_board
POSTGRES_PASSWORD=change-me

# ── Governance signing (HMAC keyring) ─────────────────────────────────────────
# Dev falls back to a local key. Set CB_GOVERNANCE_STRICT_SIGNING=true in prod.
# CB_GOVERNANCE_SIGNING_KEYS_JSON={"prod-2026":"<random 32+ char secret>"}
# CB_GOVERNANCE_ACTIVE_KEY_ID=prod-2026
# CB_GOVERNANCE_STRICT_SIGNING=true

# ── Inference provider ────────────────────────────────────────────────────────
# The active provider and its api_key_env name are set in /api/v1/settings.
# The env var named in api_key_env must be present here at runtime.
# FEATHERLESS_API_KEY=<deployment-specific>
# OPENAI_API_KEY=<deployment-specific>
# For model-native level4 routing to a remote model endpoint:
# MODEL_ROUTER_REMOTE_URL=https://api.featherless.ai/v1/chat/completions
# MODEL_API_KEY=<same key as your inference provider>

# ── Connector mode ────────────────────────────────────────────────────────────
# Controls whether external connectors make real API calls.
# Values: live (real calls) | mock (stub responses) | test (default, same as mock)
CB_CONNECTOR_MODE=mock

# ── Network / adapter policy ──────────────────────────────────────────────────
# BOARD_NETWORK_MODE=controlled       # offline | controlled | restricted
# BOARD_OUTBOUND_ALLOWLIST=           # comma-separated hostnames (controlled mode)
# CB_ADAPTERS_DEFAULT_ENABLED=true
# ENABLE_DEPLOY_ADAPTER=true
# ENABLE_EMAIL_ADAPTER=true
# ENABLE_PUBLISH_ADAPTER=true

# ── Kill switch ───────────────────────────────────────────────────────────────
# CB_KILL_SWITCH=false

# ── File-backed persistence (dev/single-node) ─────────────────────────────────
# CB_DATA_DIR=.data

# ── Connectors — only needed when CB_CONNECTOR_MODE=live ─────────────────────

# Cloudflare (DNS/KV)
# CF_API_TOKEN=<Cloudflare API token with DNS:Edit and KV:Write>
# CF_ACCOUNT_ID=<Cloudflare account ID>

# Vercel (deploy landing pages)
# VERCEL_TOKEN=<Vercel personal or team access token>
# VERCEL_TEAM_ID=<team ID, omit for personal accounts>

# Stripe (products, prices, checkout)
# STRIPE_SECRET_KEY=<sk_live_* or sk_test_*>
# STRIPE_SUCCESS_URL=https://yourdomain.com/success
# STRIPE_CANCEL_URL=https://yourdomain.com/cancel

# Email via Resend
# RESEND_API_KEY=<re_*>
# EMAIL_FROM=board@yourdomain.com

# ── labor-commons catalog ─────────────────────────────────────────────────────
# LABOR_COMMONS_MODE=remote           # remote (default) | local
# LABOR_COMMONS_LOCAL_PATH=/path/to/labor-commons

# ── Web app (apps/web) ────────────────────────────────────────────────────────
# Used by the Next.js frontend to reach the API and set auth context.
INTERNAL_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_COMMONS_WORKSPACE_ID=default
NEXT_PUBLIC_COMMONS_USER_ID=operator
NEXT_PUBLIC_COMMONS_USER_ROLE=admin
