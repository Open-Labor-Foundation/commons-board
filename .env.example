# commons-board environment — EXAMPLE ONLY. Copy to .env and fill per deployment.
# Never commit a real secret. .env is gitignored.

# --- API ---
PORT=4000
NODE_ENV=development

# --- Database (omit for file-backed local dev) ---
# DATABASE_URL=postgres://commons:commons-dev@localhost:5432/commons_board
POSTGRES_PASSWORD=commons-dev

# --- Governance signing (HMAC keyring) ---
# Dev falls back to a local key. Production/strict REQUIRES a real keyring:
# CB_GOVERNANCE_SIGNING_KEYS_JSON={"prod-2026":"<random-32+char-secret>"}
# CB_GOVERNANCE_ACTIVE_KEY_ID=prod-2026
# CB_GOVERNANCE_STRICT_SIGNING=true

# --- Inference provider credentials ---
# The active provider is chosen in settings; its key is read from the env var
# named in that provider's config (api_key_env). Examples:
# FEATHERLESS_API_KEY=<deployment-specific>
# OPENAI_API_KEY=<deployment-specific>
# Local inference needs no key.

# --- labor-commons catalog source ---
# Remote (default) reads the public repo; local points at a clone for self-host.
# LABOR_COMMONS_MODE=remote
# LABOR_COMMONS_LOCAL_PATH=/path/to/labor-commons
