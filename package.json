{
  "name": "commons-board",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev": "npm run dev -w @commons-board/api",
    "migrate": "npm run migrate -w @commons-board/api"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
