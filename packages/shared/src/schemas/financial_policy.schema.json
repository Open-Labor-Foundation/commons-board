{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "commons-board/financial_policy",
  "title": "FinancialPolicy",
  "type": "object",
  "required": [
    "currency",
    "daily_spend_cap",
    "weekly_spend_cap",
    "per_transaction_cap"
  ],
  "properties": {
    "currency": { "type": "string" },
    "daily_spend_cap": { "type": "number", "minimum": 0 },
    "weekly_spend_cap": { "type": "number", "minimum": 0 },
    "per_transaction_cap": { "type": "number", "minimum": 0 },
    "categories": {
      "type": "object",
      "properties": {
        "allowed": { "type": "array", "items": { "type": "string" } },
        "forbidden": { "type": "array", "items": { "type": "string" } }
      }
    },
    "approvals": {
      "type": "object",
      "properties": {
        "required_over_amount": { "type": "number" },
        "required_for_categories": { "type": "array", "items": { "type": "string" } },
        "approver_roles": { "type": "array", "items": { "type": "string" } }
      }
    },
    "founder_constraints": {
      "type": "object",
      "properties": {
        "time_available_per_week_hours": { "type": "number" },
        "budget_range": { "type": "string" }
      }
    }
  }
}